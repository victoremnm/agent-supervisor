# Anthropic
ANTHROPIC_API_KEY=sk-ant-...   # From console.anthropic.com

# GitHub App (see GITHUB_APP_SETUP.md for creation steps)
GITHUB_APP_ID=123456           # From GitHub App settings page
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."  # PEM key (single line, \n escaped)
GITHUB_APP_INSTALLATION_ID=   # From: gh api /app/installations | jq '.[0].id'

# Target repositories (comma-separated owner/repo pairs)
TARGET_REPOS=yourname/repo1,yourname/repo2

# Langfuse observability (self-hosted, see docker-compose.yml)
LANGFUSE_SECRET_KEY=sk-lf-...  # From Langfuse dashboard -> Settings -> API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...  # From Langfuse dashboard -> Settings -> API Keys
LANGFUSE_HOST=http://localhost:3000

# Gemini (optional — only needed if using gemini-analyzer subagent)
GEMINI_API_KEY=AI...            # From aistudio.google.com
